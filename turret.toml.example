# turret.toml — Nextflow Turret configuration
#
# This file is read automatically when present in the current working directory.
# A user-level config can also be placed at ~/.config/turret/config.toml.
# All values are optional; commented-out entries show the built-in defaults.
# CLI flags (e.g. --port 9000) always override config-file values.

[server]
# host    = "0.0.0.0"    # bind address  (0.0.0.0 = all interfaces)
# port    = 8000          # HTTP port
# db      = "turret.db"  # SQLite database path
# log_dir = "turret-logs" # directory for per-launch .log files

[launcher]
# nextflow        = "nextflow"   # path to the nextflow executable
# work_dir        = ""           # default -work-dir for every launched pipeline
# default_profile = ""           # default -profile  for every launched pipeline

# --------------------------------------------------------------------------
# Authentication
# --------------------------------------------------------------------------
# mode can be "none" (default), "basic", or "oidc"
# When mode != "none", a session_secret must be set to sign session cookies.
# Generate a suitable secret with: python -c "import secrets; print(secrets.token_urlsafe(32))"

# [auth]
# mode           = "none"
# session_secret = "change-me-to-a-random-secret"

# Basic auth — single username/password
# Generate a hash with: turret hash-password mysecretpassword
# [auth.basic]
# username      = "admin"
# password_hash = "$2b$12$..."

# OpenID Connect (OIDC/OAuth2) — works with Google, Okta, Keycloak, Entra ID, etc.
# Requires: pip install nextflow-turret[oidc]
# [auth.oidc]
# client_id     = "..."
# client_secret = "..."
# discovery_url = "https://accounts.google.com/.well-known/openid-configuration"
# redirect_uri  = "http://localhost:8000/auth/callback"   # optional; auto-detected
# scopes        = ["openid", "email", "profile"]          # optional; these are the defaults
